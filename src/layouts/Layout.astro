---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '基于 Thurstonian IRT 的迫选法大五人格自适应测评。' } = Astro.props;
---

<!doctype html>
<html lang={Astro.url.pathname.includes('/en') ? 'en' : 'zh-CN'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
