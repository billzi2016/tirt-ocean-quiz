---
import '../styles/global.css';
import type { Locale } from '../i18n/locales';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const { title, description = 'Based on Thurstonian IRT forced-choice adaptive Big Five assessment.', locale = 'en' } = Astro.props;
const iconPath = `${import.meta.env.BASE_URL}icon.png`;

const langMap: Record<string, string> = {
  zh: 'zh-CN',
  en: 'en-US',
  es: 'es-ES',
  fr: 'fr-FR',
  ja: 'ja-JP',
  ru: 'ru-RU',
  ko: 'ko-KR',
  pt: 'pt-PT',
  hi: 'hi-IN',
  de: 'de-DE',
  it: 'it-IT',
  uk: 'uk-UA',
  ar: 'ar-SA',
  tr: 'tr-TR',
  nl: 'nl-NL',
  pl: 'pl-PL',
  vi: 'vi-VN',
  th: 'th-TH',
  id: 'id-ID',
  sv: 'sv-SE',
};
const pageLang = langMap[locale] || 'en-US';
---

<!doctype html>
<html lang={pageLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={iconPath} />
    <link rel="apple-touch-icon" href={iconPath} />
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('tirt-ocean-theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.classList.toggle('dark', theme === 'dark');
        } catch {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
